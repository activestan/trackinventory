# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# MongoDB connection string (MongoDB Atlas or local MongoDB instance)
MONGODB_URI=mongodb://localhost:27017/inventory_asset_tracker

# JSON Web Token secret used to sign authentication tokens
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# Email delivery settings used to send low-stock and asset alert
# notifications, via the Brevo transactional email HTTP API.
#
# IMPORTANT: as of September 26, 2025, Render's free web service tier
# blocks all outbound traffic on the traditional SMTP ports (25, 465,
# 587), which silently breaks Nodemailer/SMTP-based email sending when
# deployed there. Using Brevo's HTTP API (over standard HTTPS/port 443)
# avoids this restriction entirely, so alerts are delivered reliably even
# on Render's free tier.
#
# Sign up at https://www.brevo.com (free, 300 emails/day), then go to
# Settings > SMTP & API > API Keys tab > Generate a new API key.
# Also verify your sending email address under Senders, Domains &
# Dedicated IPs > Senders, so it is not substituted with a Brevo-branded
# address on delivery.
BREVO_API_KEY=your_brevo_api_key_starting_with_xkeysib
ALERT_FROM_EMAIL=alerts@yourbusiness.com
ALERT_FROM_NAME=Inventory & Asset Tracking System

# Fallback recipient used only if no Administrator/Manager user accounts
# exist yet. Once such accounts exist, alerts are sent to all of them
# automatically instead.
ALERT_RECIPIENT_EMAIL=manager@yourbusiness.com

# Optional: if BREVO_API_KEY is not set, the system falls back to plain
# SMTP (via Nodemailer) using these settings instead. Only use this for
# local development or hosting providers that do not block SMTP ports.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_brevo_login_email@example.com
# SMTP_PASS=your_brevo_smtp_key

# How often (cron expression) the alert engine checks stock & asset thresholds
ALERT_CRON_SCHEDULE=*/30 * * * *

# Shared secret required to call POST /api/alerts/run-check, which lets an
# external scheduler (e.g. https://cron-job.org, free) trigger an
# immediate alert check. Recommended on free-tier hosting, where the
# server can sleep and miss the in-process cron's scheduled tick.
# Generate any long random string for this value.
ALERT_TRIGGER_KEY=change_this_to_a_long_random_secret
